[Unit]
Description=D65 ingest from S3 to VictoriaMetrics
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/ubuntu/ingest/current
EnvironmentFile=-/etc/ingest/ingest.env
ExecStart=/home/ubuntu/ingest/current/deploy/bin/run_d65_ingest.sh
StandardOutput=append:/home/ubuntu/ingest/logs/d65.log
StandardError=append:/home/ubuntu/ingest/logs/d65.log
Nice=10

[Install]
WantedBy=default.target
