[Unit]
Description=D65 ingest from S3 to VictoriaMetrics
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/ingest/current
EnvironmentFile=-/etc/ingest/ingest.env
ExecStart=/home/ubuntu/ingest/current/deploy/bin/run_d65_ingest.sh
StandardOutput=append:/var/log/ingest/d65.log
StandardError=append:/var/log/ingest/d65.log
Nice=10

[Install]
WantedBy=multi-user.target
