# Copy to /etc/ingest/ingest.env on the server.
# Keep private endpoints and credentials ONLY on server.

# Polling behavior
D65_DEFAULT_LOOKBACK_SECONDS=600
D65_OVERLAP_SECONDS=120
B3SR_DEFAULT_LOOKBACK_SECONDS=600
B3SR_OVERLAP_SECONDS=120

# Streaming strategy
D65_S3_STREAMING_STRATEGY=auto
B3SR_S3_STREAMING_STRATEGY=auto

# Server endpoints (set to local/container DNS on victoriametrics host)
D65_SERVER=http://localhost:8428
B3SR_SERVER=http://localhost:8431

# B3SR source bucket
B3SR_S3_BUCKET=b3sr-telematics
